// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================================================
// User Model - Matches Frontend User Entity
// ============================================================================

model User {
  id              String   @id @default(cuid())
  mat             String   @unique
  name            String
  org             String?
  direct          String?
  costCenter      Int?
  birthday        String?
  schoolLevel     String?
  department      String?
  jobName         String
  badgeNum        Int
  superior        String?
  stock           Int      @default(0)
  badgeId         String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  admin           Admin?

  @@index([mat])
  @@index([badgeId])
  @@index([org])
  @@index([department])
}

// ============================================================================
// Admin Model - Matches Frontend Admin Entity
// ============================================================================

model Admin {
  id              String   @id @default(cuid())
  mat             String   @unique
  name            String
  org             String?
  jobName         String
  badgeNum        Int
  badgeId         String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([mat])
  @@index([badgeId])
  @@index([org])
}

// ============================================================================
// Stock Model
// ============================================================================

model Stock {
  id        String   @id @default(cuid())
  itemName  String
  description String?
  sku       String   @unique
  quantity  Int      @default(0)
  reorderLevel Int   @default(20)
  unit      String   @default("pack")
  price     Float    @default(0)
  supplier  String?
  location  String?
  category  String   @default("General")
  batchNumber String?
  expiryDate DateTime?
  images    String?  // JSON array stored as string
  tags      String?  // JSON array stored as string
  lastRestocked DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sku])
  @@index([category])
  @@index([quantity])
  @@index([location])
  @@fulltext([itemName, description])
}

// ============================================================================
// GPIO Log Model
// ============================================================================

model GPIOLog {
  id        String   @id @default(cuid())
  deviceId  String?
  channel   Int
  action    String   // 'pressed' | 'released' | 'triggered'
  relayPin  Int
  relayState String? // 'HIGH' | 'LOW' | 'ON' | 'OFF'
  duration  Int?
  metadata  Json?
  userId    String?
  createdAt DateTime @default(now())

  @@index([channel])
  @@index([relayPin])
  @@index([createdAt])
}
